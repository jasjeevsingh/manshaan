# Manshaan Frontend Environment Variables
# Copy to .env.local and fill in your values

# Hume AI Config
# VITE_HUME_API_KEY: Your Hume Secret Key (starts with sk-)
VITE_HUME_API_KEY=
# VITE_HUME_CONFIG_ID: Your Hume EVI Config ID from the dashboard
VITE_HUME_CONFIG_ID=

# API Configuration
VITE_API_BASE_URL=http://localhost:8000/api

# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

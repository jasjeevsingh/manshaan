{
    "rewrites": [
        {
            "source": "/api/:match*",
            "destination": "https://manshaan-production.up.railway.app/api/:match*"
        },
        {
            "source": "/((?!assets/|favicon\\.jpeg|logo/|.*\\.png|.*\\.jpg|.*\\.svg|.*\\.css|.*\\.js).*)",
            "destination": "/index.html"
        }
    ]
}
# Manshaan Backend Environment Variables
# Copy to .env and fill in your values

# OpenAI: Used for GPT-4o Vision drawing analysis
OPENAI_API_KEY=sk-your-openai-api-key

# Google: Used for Gemini clinical report generation  
GOOGLE_API_KEY=your-gemini-api-key

# Hume: Used for EVI (Empathic Voice Interface) token generation
HUME_API_KEY=sk-your-hume-api-key
HUME_SECRET_KEY=your-hume-secret-key

# App Settings
DEBUG=True
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Supabase: Used for authentication and database
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

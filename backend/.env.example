# Manshaan Backend Environment Variables
# Copy to .env and fill in your values

# OpenRouter: primary key for all backend LLM calls (text + vision). OpenAI-compatible API.
# Get a key at https://openrouter.ai/keys — model slugs: https://openrouter.ai/models
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Optional attribution (recommended by OpenRouter)
# OPENROUTER_HTTP_REFERER=https://yourapp.example
# OPENROUTER_APP_TITLE=Manshaan Clinical Platform
# Switch models without code changes (provider/model slugs, e.g. openai/gpt-4o-mini, google/gemini-2.0-flash-001)
LLM_TEXT_MODEL=google/gemini-2.0-flash-001
LLM_VISION_MODEL=openai/gpt-4o
# Optional: alternate text model for simplification fallback (defaults to LLM_TEXT_MODEL if unset)
# LLM_FALLBACK_TEXT_MODEL=openai/gpt-4o

# Legacy (optional; not used by app LLM paths when OpenRouter is configured)
OPENAI_API_KEY=sk-your-openai-api-key
GOOGLE_API_KEY=your-gemini-api-key

# Hume: Used for EVI (Empathic Voice Interface) token generation
HUME_API_KEY=sk-your-hume-api-key
HUME_SECRET_KEY=your-hume-secret-key

# App Settings
DEBUG=True
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Supabase: Used for authentication and database
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

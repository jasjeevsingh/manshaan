# Manshaan Backend Environment Variables
# Copy to .env and fill in your values

# OpenAI: Used for GPT-4o Vision drawing analysis
OPENAI_API_KEY=sk-your-openai-api-key

# Google: Used for Gemini clinical report generation  
GOOGLE_API_KEY=your-gemini-api-key

# Hume: (Optional) Used for backend emotion data processing
HUME_API_KEY=sk-your-hume-api-key

# App Settings
DEBUG=True
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
